<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ALIVFEST</title>
  <meta name="description" content="ALIVFEST — Accra's luxury carnival, music, and nightlife experience." />
  <style>
    :root {
      --bg: #050505;
      --bg-soft: rgba(255,255,255,0.04);
      --line: rgba(255, 191, 87, 0.22);
      --gold: #ffcc74;
      --gold-2: #ff9f2d;
      --gold-3: #fff0b8;
      --text: #f7f1e8;
      --muted: rgba(247, 241, 232, 0.72);
      --shadow: 0 0 30px rgba(255, 170, 60, 0.22), 0 0 80px rgba(255, 140, 0, 0.12);
      --radius: 24px;
      --max: 1220px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 50% -5%, rgba(255, 180, 80, 0.16), transparent 36%),
        radial-gradient(circle at 0% 30%, rgba(255, 120, 0, 0.08), transparent 30%),
        radial-gradient(circle at 100% 60%, rgba(255, 174, 66, 0.08), transparent 30%),
        #050505;
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background-image: radial-gradient(rgba(255, 210, 120, 0.16) 0.8px, transparent 0.8px);
      background-size: 22px 22px;
      opacity: 0.12;
      pointer-events: none;
      z-index: 0;
    }

    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }

    .shell {
      position: relative;
      z-index: 1;
      width: min(var(--max), calc(100% - 28px));
      margin: 0 auto;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(16px);
      background: rgba(5,5,5,0.76);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .topbar-inner {
      width: min(var(--max), calc(100% - 28px));
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      min-height: 76px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      letter-spacing: 0.22em;
      font-size: 12px;
      font-weight: 700;
    }

    .brand-badge {
      width: 16px;
      height: 16px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--gold-3), var(--gold-2));
      box-shadow: 0 0 18px rgba(255, 188, 84, 0.55);
    }

    .nav {
      display: flex;
      align-items: center;
      gap: 28px;
      font-size: 12px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.78);
    }

    .nav a:hover { color: white; }

    .menu-toggle {
      display: none;
      background: transparent;
      border: 1px solid rgba(255,255,255,0.16);
      color: white;
      border-radius: 14px;
      padding: 10px 14px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .mobile-nav {
      display: none;
      border-top: 1px solid rgba(255,255,255,0.08);
      background: rgba(0,0,0,0.92);
    }

    .mobile-nav.open { display: block; }

    .mobile-nav a {
      display: block;
      padding: 16px 14px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-size: 12px;
      color: rgba(255,255,255,0.84);
    }

    .hero {
      padding: 26px 0 38px;
    }

    .hero-card {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.09);
      border-radius: 34px;
      background: linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.06), 0 10px 80px rgba(0,0,0,0.4);
    }

    .hero-card::before,
    .hero-card::after {
      content: "";
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      width: 86%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255, 196, 95, 0.8), transparent);
      box-shadow: 0 0 14px rgba(255, 162, 48, 0.35);
      z-index: 1;
    }

    .hero-card::before { top: 0; }
    .hero-card::after { bottom: 0; }

    .hero-inner {
      position: relative;
      padding: 28px 20px 36px;
    }

    .hero-glow {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 50% 26%, rgba(255, 188, 84, 0.14), transparent 30%),
        radial-gradient(circle at 15% 50%, rgba(255, 120, 0, 0.10), transparent 30%),
        radial-gradient(circle at 85% 48%, rgba(255, 188, 84, 0.10), transparent 30%);
      z-index: 0;
    }

    .hero-logo-wrap {
      position: relative;
      max-width: 1100px;
      margin: 0 auto;
      padding: 8px;
    }

    .hero-logo-wrap::before {
      content: "";
      position: absolute;
      inset: -10px;
      border-radius: 40px;
      background: radial-gradient(circle at 50% 40%, rgba(255, 181, 66, 0.28), transparent 55%);
      filter: blur(26px);
      z-index: 0;
      animation: pulseGlow 4s ease-in-out infinite;
    }

    .hero-logo {
      position: relative;
      z-index: 1;
      border-radius: 28px;
      border: 1px solid rgba(255,255,255,0.08);
      overflow: hidden;
      background: #080808;
      box-shadow: var(--shadow);
    }

    .hero-logo img {
      width: 100%;
      object-fit: cover;
    }

    .electric {
      position: absolute;
      inset: 18% 7% auto 7%;
      height: 160px;
      opacity: 0.75;
      filter: blur(0.2px);
      mix-blend-mode: screen;
      pointer-events: none;
      z-index: 2;
      animation: drift 6s ease-in-out infinite alternate;
    }

    .electric::before,
    .electric::after {
      content: "";
      position: absolute;
      inset: 0;
      background-repeat: no-repeat;
      background-size: 100% 100%;
    }

    .electric::before {
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 1200 220' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 120 C 80 80, 130 155, 200 105 S 335 60, 410 120 S 545 170, 625 110 S 760 55, 840 120 S 975 180, 1055 105 S 1140 85, 1200 110' fill='none' stroke='%23ffd56d' stroke-width='4' stroke-linecap='round'/%3E%3Cpath d='M80 152 L 110 115 L 126 140 L 168 82 L 194 112 L 240 74 L 276 104 L 310 56 L 350 95 L 390 68 L 430 114 L 460 98 L 488 140 L 540 85 L 560 105 L 602 74 L 630 98 L 680 58 L 710 86 L 760 66 L 798 102 L 838 72 L 860 106 L 920 54 L 958 90 L 994 74 L 1030 112 L 1088 68 L 1130 96' fill='none' stroke='%23ffb133' stroke-width='3' stroke-linecap='round'/%3E%3C/svg%3E");
      filter: drop-shadow(0 0 10px rgba(255, 200, 120, 0.9)) drop-shadow(0 0 22px rgba(255, 153, 0, 0.55));
      opacity: 0.95;
      animation: flicker 1.8s linear infinite;
    }

    .electric::after {
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 1200 220' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 106 C 95 148, 140 72, 205 112 S 338 160, 410 98 S 560 50, 635 112 S 760 158, 840 100 S 980 46, 1050 110 S 1150 140, 1200 102' fill='none' stroke='%23fff1be' stroke-width='2.2' stroke-linecap='round'/%3E%3C/svg%3E");
      opacity: 0.7;
      filter: drop-shadow(0 0 8px rgba(255, 240, 190, 0.8));
      animation: flicker 1.2s linear infinite reverse;
    }

    .meta-line {
      margin-top: 24px;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 10px 14px;
      text-align: center;
      font-size: 12px;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.72);
    }

    .dot {
      width: 4px;
      height: 4px;
      border-radius: 999px;
      background: rgba(255, 196, 95, 0.9);
      box-shadow: 0 0 8px rgba(255, 196, 95, 0.5);
    }

    .cta-row {
      margin-top: 26px;
      display: flex;
      justify-content: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 50px;
      padding: 0 24px;
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,0.12);
      font-size: 13px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      transition: 180ms ease;
      cursor: pointer;
    }

    .btn-primary {
      color: #180e02;
      background: linear-gradient(135deg, var(--gold-3), var(--gold), var(--gold-2));
      border-color: rgba(255, 200, 120, 0.55);
      box-shadow: 0 0 22px rgba(255, 174, 66, 0.28);
    }

    .btn-primary:hover { transform: translateY(-1px); opacity: 0.96; }

    .btn-secondary {
      color: var(--gold-3);
      background: rgba(255, 196, 95, 0.05);
      border-color: rgba(255, 196, 95, 0.24);
    }

    .btn-secondary:hover { background: rgba(255, 196, 95, 0.11); }

    .section {
      padding: 56px 0;
    }

    .center-copy {
      text-align: center;
      max-width: 780px;
      margin: 0 auto;
    }

    .eyebrow {
      font-size: 12px;
      letter-spacing: 0.30em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.6);
      margin-bottom: 12px;
    }

    h2 {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      font-weight: 500;
      font-size: clamp(40px, 5vw, 68px);
      line-height: 1;
      letter-spacing: -0.03em;
    }

    h2 .accent, h3 .accent { color: var(--gold); }

    .center-copy p {
      margin: 14px auto 0;
      max-width: 680px;
      color: var(--muted);
      font-size: 20px;
      line-height: 1.5;
    }

    .cards {
      margin-top: 32px;
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
    }

    .card {
      position: relative;
      overflow: hidden;
      min-height: 248px;
      border-radius: 24px;
      border: 1px solid rgba(255,255,255,0.10);
      background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
      padding: 22px 18px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
      transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: -20% auto auto -10%;
      width: 120px;
      height: 120px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(255, 190, 80, 0.22), transparent 70%);
      filter: blur(18px);
      opacity: 0;
      transition: opacity 220ms ease;
    }

    .card:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 196, 95, 0.28);
      box-shadow: 0 8px 34px rgba(0,0,0,0.22), 0 0 26px rgba(255, 174, 66, 0.12);
    }

    .card:hover::before { opacity: 1; }

    .card.featured {
      border-color: rgba(255, 196, 95, 0.35);
      box-shadow: 0 0 32px rgba(255, 174, 66, 0.14);
    }

    .card-icon {
      width: 64px;
      height: 64px;
      display: grid;
      place-items: center;
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.10);
      font-size: 30px;
      background: rgba(0,0,0,0.28);
      color: var(--gold);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
    }

    .card h3 {
      margin: 22px 0 10px;
      font-size: 17px;
      letter-spacing: 0.17em;
      line-height: 1.28;
      text-transform: uppercase;
      font-weight: 700;
      color: var(--gold-3);
    }

    .card p {
      margin: 0;
      font-size: 15px;
      line-height: 1.55;
      color: rgba(255,255,255,0.70);
    }

    .divider {
      width: 100%;
      height: 1px;
      margin-top: 44px;
      background: linear-gradient(90deg, transparent, rgba(255, 196, 95, 0.6), transparent);
      box-shadow: 0 0 12px rgba(255, 196, 95, 0.16);
    }

    .vip-grid {
      display: grid;
      grid-template-columns: 1.06fr 0.94fr;
      gap: 18px;
      align-items: stretch;
      margin-top: 10px;
    }

    .panel {
      position: relative;
      overflow: hidden;
      border-radius: 28px;
      border: 1px solid rgba(255,255,255,0.09);
      background: linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.03));
      padding: 28px;
    }

    .panel::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 80% 20%, rgba(255, 188, 84, 0.12), transparent 32%);
      pointer-events: none;
    }

    .panel h3 {
      margin: 0;
      font-size: clamp(30px, 4vw, 48px);
      line-height: 1.05;
      letter-spacing: -0.03em;
      font-weight: 600;
    }

    .panel p, .panel li {
      color: rgba(255,255,255,0.72);
      line-height: 1.6;
      font-size: 16px;
    }

    .feature-list {
      margin: 20px 0 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 12px;
    }

    .feature-list li {
      padding-left: 18px;
      position: relative;
    }

    .feature-list li::before {
      content: "•";
      position: absolute;
      left: 0;
      top: 0;
      color: var(--gold);
    }

    .waitlist-form {
      margin-top: 22px;
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .waitlist-form input {
      flex: 1 1 260px;
      min-height: 50px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.10);
      background: rgba(0,0,0,0.26);
      color: white;
      padding: 0 16px;
      font-size: 15px;
      outline: none;
    }

    .waitlist-form input:focus { border-color: rgba(255, 196, 95, 0.40); }
    .waitlist-form input::placeholder { color: rgba(255,255,255,0.34); }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid rgba(255, 196, 95, 0.20);
      background: rgba(255, 196, 95, 0.05);
      color: var(--gold-3);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .notice {
      margin-top: 10px;
      font-size: 12px;
      color: rgba(255,255,255,0.45);
    }

    .footer {
      padding: 28px 0 46px;
      border-top: 1px solid rgba(255,255,255,0.08);
      margin-top: 10px;
    }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .footer small {
      display: block;
      margin-top: 6px;
      color: rgba(255,255,255,0.46);
      font-size: 12px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .footer-links {
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 12px;
      color: rgba(255,255,255,0.64);
    }

    .footer-links a:hover { color: white; }

    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 700ms ease, transform 700ms ease;
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    @keyframes pulseGlow {
      0%, 100% { opacity: 0.8; transform: scale(0.98); }
      50% { opacity: 1; transform: scale(1.02); }
    }

    @keyframes flicker {
      0%, 100% { opacity: 0.88; }
      10% { opacity: 0.56; }
      20% { opacity: 0.92; }
      40% { opacity: 0.68; }
      60% { opacity: 0.98; }
      80% { opacity: 0.74; }
    }

    @keyframes drift {
      0% { transform: translateY(0) scaleX(1); }
      100% { transform: translateY(6px) scaleX(1.01); }
    }

    @media (max-width: 1100px) {
      .cards { grid-template-columns: repeat(3, 1fr); }
    }

    @media (max-width: 820px) {
      .nav { display: none; }
      .menu-toggle { display: inline-flex; }
      .cards { grid-template-columns: repeat(2, 1fr); }
      .vip-grid { grid-template-columns: 1fr; }
      .hero-inner { padding: 20px 14px 28px; }
      .electric { inset: 18% 4% auto 4%; height: 120px; }
      .center-copy p { font-size: 18px; }
    }

    @media (max-width: 560px) {
      .topbar-inner { min-height: 70px; }
      .cards { grid-template-columns: 1fr; }
      .meta-line { font-size: 11px; letter-spacing: 0.18em; }
      .btn { width: 100%; }
      .cta-row { gap: 10px; }
      .panel, .card { border-radius: 22px; }
      .hero-card { border-radius: 28px; }
      h2 { font-size: 42px; }
      .center-copy p { font-size: 17px; }
      .panel { padding: 22px; }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <a class="brand" href="#top" aria-label="ALIVFEST home">
        <span class="brand-badge"></span>
        <span>ALIVFEST</span>
      </a>

      <nav class="nav" aria-label="Main navigation">
        <a href="#enter">Enter Aliv</a>
        <a href="#access">Access</a>
        <a href="#come">Come Aliv</a>
        <a href="#vip">VIP Society</a>
        <a href="#shop">DIR Shop</a>
      </nav>

      <button class="menu-toggle" id="menuToggle" aria-expanded="false" aria-controls="mobileNav">Menu</button>
    </div>
    <div class="mobile-nav" id="mobileNav">
      <div class="shell">
        <a href="#enter">Enter Aliv</a>
        <a href="#access">Access</a>
        <a href="#come">Come Aliv</a>
        <a href="#vip">VIP Society</a>
        <a href="#shop">DIR Shop</a>
      </div>
    </div>
  </header>

  <main class="shell" id="top">
    <section class="hero reveal">
      <div class="hero-card">
        <div class="hero-glow"></div>
        <div class="hero-inner">
          <div class="hero-logo-wrap">
            <div class="hero-logo">
              <img src="alivfest-logo.jpg" alt="ALIVFEST logo" />
              <div class="electric" aria-hidden="true"></div>
            </div>
          </div>

          <div class="meta-line">
            <span>December 17 — January 4</span>
            <span class="dot"></span>
            <span>Multiple Stages</span>
            <span class="dot"></span>
            <span>Curated Villages</span>
            <span class="dot"></span>
            <span>VIP Society</span>
          </div>

          <div class="cta-row">
            <a class="btn btn-primary" href="#tickets">Get Tickets</a>
            <a class="btn btn-secondary" href="#enter">Explore the Experience</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section reveal" id="enter">
      <div class="center-copy">
        <div class="eyebrow">Curated moments from day to night</div>
        <h2>The Experience<span class="accent">.</span></h2>
        <p>Luxury carnival energy, premium nightlife, immersive activations, and a festival identity built to feel bigger than a regular event flyer with a pulse.</p>
      </div>

      <div class="cards">
        <article class="card">
          <div class="card-icon">🍽️</div>
          <h3>Food Village</h3>
          <p>Curated cuisine from around the world with premium presentation and destination-level flavor.</p>
        </article>

        <article class="card">
          <div class="card-icon">🎡</div>
          <h3>Carnival Rides</h3>
          <p>Thrilling rides, skyline moments, and unforgettable views that turn content into currency.</p>
        </article>

        <article class="card">
          <div class="card-icon">🎯</div>
          <h3>Carnival Games</h3>
          <p>Classic challenges remixed with prizes, social competition, and festival bragging rights.</p>
        </article>

        <article class="card featured" id="access">
          <div class="card-icon">🔥</div>
          <h3>Immersive Activations</h3>
          <p>Brand experiences, photo moments, and premium environments that feel made for sponsors and story capture.</p>
        </article>

        <article class="card" id="come">
          <div class="card-icon">🕺</div>
          <h3>Party Area</h3>
          <p>Epic DJ sets, after-dark energy, and a nightlife zone designed to keep the city talking.</p>
        </article>
      </div>

      <div class="divider"></div>
    </section>

    <section class="section reveal" id="vip">
      <div class="vip-grid">
        <div class="panel">
          <div class="pill">Premium Access</div>
          <h3>VIP Society<span class="accent">.</span></h3>
          <p>Fast entry, elevated viewing, premium lounge energy, and the kind of treatment that makes the crowd understand exactly who came to play.</p>
          <ul class="feature-list">
            <li>Priority entry lane and premium check-in</li>
            <li>VIP lounge seating and elevated sightlines</li>
            <li>Bottle service and curated host support</li>
            <li>Luxury content moments and elite sponsor access</li>
          </ul>
          <div class="cta-row" style="justify-content:flex-start; margin-top:24px;">
            <a class="btn btn-primary" href="#tickets">Request VIP</a>
            <a class="btn btn-secondary" href="#shop">Sponsor / Partner</a>
          </div>
        </div>

        <div class="panel" id="tickets">
          <div class="pill">Coming Soon</div>
          <h3>Ticket Drops + Lineup Announcements</h3>
          <p>Use this block for your waitlist now, then swap in Paystack, Ticket Tailor, or your checkout link when it is time to collect real money instead of applause.</p>
          <form class="waitlist-form" onsubmit="event.preventDefault(); alert('Waitlist saved. Connect this form to your email platform next.');">
            <input type="email" placeholder="Email address" required />
            <button type="submit" class="btn btn-primary">Join Waitlist</button>
          </form>
          <div class="notice">By joining, visitors agree to receive ALIVFEST updates.</div>
        </div>
      </div>
    </section>

    <footer class="footer" id="shop">
      <div class="footer-inner">
        <div>
          <strong style="letter-spacing:0.20em; text-transform:uppercase; font-size:13px;">ALIVFEST</strong>
          <small>© <span id="year"></span> • Accra • December Season</small>
        </div>
        <div class="footer-links">
          <a href="#enter">Enter Aliv</a>
          <a href="#access">Access</a>
          <a href="#vip">VIP Society</a>
          <a href="#tickets">Tickets</a>
        </div>
      </div>
    </footer>
  </main>

  <script>
    const menuToggle = document.getElementById('menuToggle');
    const mobileNav = document.getElementById('mobileNav');

    menuToggle?.addEventListener('click', () => {
      const open = mobileNav.classList.toggle('open');
      menuToggle.setAttribute('aria-expanded', String(open));
    });

    document.querySelectorAll('.mobile-nav a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileNav.classList.remove('open');
        menuToggle.setAttribute('aria-expanded', 'false');
      });
    });

    document.getElementById('year').textContent = new Date().getFullYear();

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.14 });

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
</body>
</html>
